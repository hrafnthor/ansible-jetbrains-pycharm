{
    "title": "pycharm",
    "description": "schema for management of the Python IDE Pycharm",
    "type": "object",
    "properties":
    {
        "location":
        {
            "type": "object",
            "properties":
            {
                "path":
                {
                    "ref": "#/definitions/non-empty-string"
                },
                "owner":
                {
                    "ref": "#/definitions/non-empty-string"
                },
                "group":
                {
                    "ref": "#/definitions/non-empty-string"
                },
                "mode":
                {
                    "ref": "#/definitions/non-empty-string"
                }
            }
        },
        "clients":
        {
            "type": "array",
            "items":
            {
                "type": "object",
                "properties":
                {
                    "version":
                    {
                        "description": "The version to install.",
                        "ref": "#/definitions/non-empty-string"
                    },
                    "checksum":
                    {
                        "description": "The checksum of the archived version being installed.",
                        "ref": "#/definitions/non-empty-string"
                    },
                    "remove":
                    {
                        "description": "Indicates if this version should be removed or not",
                        "type": "boolean"
                    },
                    "desktop":
                    {
                        "description": "Describes the desktop entry that should be created for the version.",
                        "type": "object",
                        "properties":
                        {
                            "name":
                            {
                                "description": "The name that the desktop entry should have, and shows up when searching for desktop applications.",
                                "$ref": "#/definitions/non-empty-string"
                            },
                            "keywords":
                            {
                                "description": "A list of keywords to add to the desktop entry for easier search",
                                "$ref": "#/definitions/non-empty-string-array"
                            },
                            "remove":
                            {
                                "description": "Indicates if the desktop entry should be removed for this version.",
                                "type": "boolean"
                            }
                        }
                    }
                },
                "if":
                {
                    "properties":
                    {
                        "remove":
                        {
                            "const": false
                        }
                    }
                },
                "then":
                {
                    "required":
                    [
                        "version",
                        "checksum"
                    ]
                },
                "else":
                {
                    "required":
                    [
                        "version"
                    ]
                }
            }
        }
    },
    "definitions":
    {
        "non-empty-string":
        {
            "type": "string",
            "minLength": 1
        },
        "non-empty-string-array":
        {
            "type": "array",
            "minItems": 1,
            "items":
            {
                "$ref": "#/definitions/non-empty-string"
            }
        }
    }
}
